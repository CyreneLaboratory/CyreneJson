<Project>
  <Target Name="CyreneJson"
          BeforeTargets="CoreCompile"
          DependsOnTargets="ResolveAssemblyReferences"
          Condition="'$(DesignTimeBuild)' != 'true'">
    <WriteLinesToFile File="$(IntermediateOutputPath)CyreneJson.refs"
                      Lines="@(ReferencePath)"
                      Overwrite="true" />
    <Exec Command="dotnet exec &quot;$(MSBuildThisFileDirectory)..\tools\net8.0\CyreneJson.BuildTask.dll&quot; &quot;$(MSBuildProjectDirectory)&quot; &quot;$(IntermediateOutputPath)CyreneJson.refs&quot; &quot;$(IntermediateOutputPath)generated\CyreneJson&quot;" />
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)generated\CyreneJson\*.g.cs" />
    </ItemGroup>
  </Target>
</Project>
