<Project>
  <Target Name="CyreneJsonCollectInputs"
          DependsOnTargets="ResolveAssemblyReferences">
    <ItemGroup>
      <CyreneJsonSource Include="$(MSBuildProjectDirectory)\**\*.cs"
                        Exclude="$(MSBuildProjectDirectory)\obj\**;$(MSBuildProjectDirectory)\bin\**" />
    </ItemGroup>
    <WriteLinesToFile File="$(IntermediateOutputPath)CyreneJson.refs"
                      Lines="@(ReferencePath)"
                      Overwrite="true" />
  </Target>

  <Target Name="CyreneJson"
          BeforeTargets="CoreCompile"
          DependsOnTargets="CyreneJsonCollectInputs"
          Inputs="@(CyreneJsonSource);$(IntermediateOutputPath)CyreneJson.refs"
          Outputs="$(IntermediateOutputPath)generated\CyreneJson\.stamp"
          Condition="'$(DesignTimeBuild)' != 'true'">
    <RemoveDir Directories="$(IntermediateOutputPath)generated\CyreneJson" />
    <Exec Command="dotnet exec &quot;$(MSBuildThisFileDirectory)..\tools\net8.0\CyreneJson.BuildTask.dll&quot; &quot;$(MSBuildProjectDirectory)&quot; &quot;$(IntermediateOutputPath)CyreneJson.refs&quot; &quot;$(IntermediateOutputPath)generated\CyreneJson&quot;" />
    <Touch Files="$(IntermediateOutputPath)generated\CyreneJson\.stamp" AlwaysCreate="true" />
  </Target>

  <Target Name="CyreneJsonInclude"
          BeforeTargets="CoreCompile"
          AfterTargets="CyreneJson"
          Condition="'$(DesignTimeBuild)' != 'true' And Exists('$(IntermediateOutputPath)generated\CyreneJson\.stamp')">
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)generated\CyreneJson\*.g.cs" />
    </ItemGroup>
  </Target>

  <Target Name="CyreneJsonClean" BeforeTargets="CoreClean">
    <RemoveDir Directories="$(IntermediateOutputPath)generated\CyreneJson" />
  </Target>
</Project>
